# Environment Variables Example

# Streamlit Port (Default: 8501)
PORT=8501

# Flask Host and Port for API (Default: 127.0.0.1:5000)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Application Mode (development, production)
APP_MODE=production

# Database Path (if using SQLite in the future)
# DATABASE_URL=sqlite:///./data/emergency.db
